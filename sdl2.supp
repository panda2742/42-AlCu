   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   obj:*radeonsi_dri.so*
}

# ──────────────────────────────────────────────────────────────
# LLVM — static command-line option tables (one-time global init)
# ──────────────────────────────────────────────────────────────
{
   LLVM_StringMap_rehash
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_ZN4llvm13StringMapImplL11RehashTableEj
   ...
}

{
   LLVM_generic_leak
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   obj:*libLLVM*
}

# ──────────────────────────────────────────────────────────────
# libstdc++ — one-shot global init via dlopen
# ──────────────────────────────────────────────────────────────
{
   libstdcxx_global_init
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   obj:*libstdc++*
}

# ──────────────────────────────────────────────────────────────
# dynamic linker — dlopen / rpath bookkeeping (not your code)
# ──────────────────────────────────────────────────────────────
{
   dl_open_worker_versions
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_dl_check_map_versions
   ...
}

{
   dl_new_object
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_dl_new_object
   ...
}

{
   dl_map_object_deps
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_dl_map_object_deps
   ...
}

{
   dl_load_cache_lookup
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_dl_load_cache_lookup
   ...
}

{
   dl_map_object_strdup
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_dl_map_object
   fun:dl_open_worker_begin
   ...
}

{
   dl_open_add_to_global_resize
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   fun:add_to_global_resize
   fun:dl_open_worker_begin
   ...
}

{
   dl_lookup_unique
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:calloc
   fun:do_lookup_unique
   ...
}

# ──────────────────────────────────────────────────────────────
# NSS / passwd lookup — opened by radeonsi getpwuid, not your code
# ──────────────────────────────────────────────────────────────
{
   nss_module_freeres
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:__nss_module_freeres
}
