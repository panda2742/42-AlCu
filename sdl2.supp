# ──────────────────────────────────────────────────────────────
# X11 — invalid reads in dl/rpath machinery (spurious on startup)
# ──────────────────────────────────────────────────────────────
{
   dl_rpath_invalid_read_is_dst
   Memcheck:Addr8
   fun:strncmp
   fun:is_dst
   ...
}

# ──────────────────────────────────────────────────────────────
# dbus — still-reachable internal registrations
# ──────────────────────────────────────────────────────────────
{
   dbus_register_shutdown
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_dbus_register_shutdown_func
}

{
   dbus_generic_leak
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   obj:*libdbus*
}

