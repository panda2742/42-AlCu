# Valgrind suppression file for SDL2 + X11 + dbus + radeonsi/LLVM
# Generated from AlCu project leak output (Valgrind 3.18.1)
# Usage: valgrind --suppressions=sdl2.supp ./AlCu

# ──────────────────────────────────────────────────────────────
# SDL2 — generic still-reachable leaks from SDL_Init / subsystems
# ──────────────────────────────────────────────────────────────
{
   SDL2_init_leak
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   obj:*libSDL2*
}

